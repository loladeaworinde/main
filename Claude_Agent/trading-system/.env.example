# ─── Database ───────────────────────────────────────────────
POSTGRES_USER=trader
POSTGRES_PASSWORD=change_me
POSTGRES_DB=trading_db
DATABASE_URL=postgresql+asyncpg://trader:change_me@localhost:5432/trading_db

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── App ────────────────────────────────────────────────────
SECRET_KEY=change_me_to_random_string
DEBUG=true
LOG_LEVEL=INFO

# ─── Trading Mode ───────────────────────────────────────────
# Options: paper | live
TRADING_MODE=paper
PAPER_STARTING_CAPITAL=100000.00

# ─── Robinhood ──────────────────────────────────────────────
ROBINHOOD_USERNAME=
ROBINHOOD_PASSWORD=
ROBINHOOD_TOTP_SECRET=          # For 2FA — use pyotp to generate

# ─── Webull ─────────────────────────────────────────────────
WEBULL_USERNAME=
WEBULL_PASSWORD=
WEBULL_DEVICE_ID=               # Generated on first login
WEBULL_TRADING_PIN=

# ─── Alpaca (recommended for paper trading) ─────────────────
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ─── Data Providers ─────────────────────────────────────────
POLYGON_API_KEY=                # polygon.io — free tier works
ALPHA_VANTAGE_KEY=              # alphavantage.co — free tier
FINNHUB_API_KEY=                # finnhub.io — free tier

# ─── Crypto ─────────────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true            # true = use testnet for paper trading

COINBASE_API_KEY=
COINBASE_API_SECRET=

# ─── Sentiment / News ───────────────────────────────────────
NEWS_API_KEY=                   # newsapi.org — free tier
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=TradingBot/1.0

# ─── Claude API (for AI-powered sentiment + analysis) ───────
ANTHROPIC_API_KEY=

# ─── Risk Management Defaults ───────────────────────────────
MAX_PORTFOLIO_HEAT=0.20         # Max 20% of portfolio at risk at once
MAX_POSITION_SIZE=0.05          # Max 5% of portfolio in single position
MAX_DAILY_LOSS=0.03             # Stop trading if down 3% in a day
MAX_DRAWDOWN=0.15               # Halt system if 15% drawdown from peak
KELLY_FRACTION=0.25             # Use 25% of full Kelly for sizing

# ─── Strategy Weights (must sum to 1.0) ─────────────────────
STRATEGY_MOMENTUM_WEIGHT=0.25
STRATEGY_SWING_WEIGHT=0.25
STRATEGY_MEAN_REVERSION_WEIGHT=0.20
STRATEGY_OPTIONS_WEIGHT=0.15
STRATEGY_CRYPTO_WEIGHT=0.15
